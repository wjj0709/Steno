{
  "name": "steno",
  "version": "0.1.0",
  "private": true,
  "description": "Steno — 跨平台桌面速记应用（Tauri 2 + Rust + Vue 3）",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit --skipLibCheck && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "icons": "tauri icon src-tauri/icons/icon.svg --output src-tauri/icons",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "lint": "oxlint --fix && eslint --fix .",
    "fmt": "oxfmt",
    "commit": "tsx src/scripts/bin.ts git-commit",
    "commit:zh": "tsx src/scripts/bin.ts git-commit -l=zh-cn",
    "cleanup": "tsx src/scripts/bin.ts cleanup",
    "release": "tsx src/scripts/bin.ts release",
    "update-pkg": "tsx src/scripts/bin.ts update-pkg",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@iconify/vue": "5.0.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@vscode/markdown-it-katex": "^1.1.2",
    "@vueuse/core": "14.2.1",
    "dayjs": "1.11.19",
    "defu": "6.1.4",
    "dompurify": "^3.4.7",
    "echarts": "^6.1.0",
    "katex": "^0.17.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "naive-ui": "2.44.1",
    "pinia": "3.0.4",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.6",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "shiki": "^4.1.0",
    "vue": "3.5.29",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.1.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/cli-progress": "^3.11.6",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "25.3.5",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@unocss/core": "66.6.8",
    "@unocss/preset-mini": "66.6.8",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "10.4.1",
    "c12": "3.3.3",
    "cac": "6.7.14",
    "cli-progress": "3.12.0",
    "consola": "3.4.2",
    "convert-gitmoji": "0.1.5",
    "enquirer": "2.4.1",
    "eslint": "10.0.3",
    "eslint-plugin-vue": "^10.9.1",
    "execa": "9.6.1",
    "jsdom": "^27.0.0",
    "kolorist": "1.8.0",
    "npm-check-updates": "19.6.3",
    "ofetch": "1.5.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "picomatch": "4.0.3",
    "rimraf": "6.1.3",
    "semver": "7.7.3",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "unocss": "^66.6.6",
    "vite": "7.3.1",
    "vite-plugin-progress": "0.0.7",
    "vite-plugin-vue-devtools": "8.0.7",
    "vitest": "^4.0.0",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.5"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm tsx src/scripts/bin.ts git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}

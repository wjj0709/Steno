{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steno",
  "version": "0.0.0",
  "identifier": "com.steno.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:21420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Steno",
        "width": 800,
        "height": 600,
        "minWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": true,
        "visible": false
      },
      {
        "label": "quicknote",
        "url": "index.html",
        "title": "Steno · 速记",
        "width": 400,
        "height": 300,
        "minWidth": 320,
        "minHeight": 220,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false,
        "transparent": false,
        "shadow": true
      },
      {
        "label": "todo-panel",
        "url": "index.html#todo-panel",
        "title": "Steno · 待办",
        "width": 320,
        "height": 480,
        "minWidth": 280,
        "minHeight": 360,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "visible": false,
        "transparent": true,
        "shadow": true
      },
      {
        "label": "clipboard-panel",
        "url": "index.html#clipboard-panel",
        "title": "Steno · 粘贴板",
        "width": 320,
        "height": 480,
        "minWidth": 280,
        "minHeight": 360,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "visible": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.steno/images/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.svg",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
